NODE_ENV=development
PORT=5000

# MongoDB Atlas standard URI fallback for environments where SRV lookup fails in Node.js
MONGO_URI=mongodb://admin:admin@cluster0-shard-00-00.7khaz.mongodb.net:27017,cluster0-shard-00-01.7khaz.mongodb.net:27017,cluster0-shard-00-02.7khaz.mongodb.net:27017/urban_farming?tls=true&authSource=admin&replicaSet=atlas-k4b46a-shard-0
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
MIGRATE_MONGO_COLLECTION=changelog
